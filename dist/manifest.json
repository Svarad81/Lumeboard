{
  "manifest_version": 3,
  "name": "LumeBoard",
  "version": "1.0.0",
  "description": "High-performance Pinterest-style bookmark manager.",
  "permissions": [
    "bookmarks",
    "tabs",
    "storage",
    "notifications",
    "activeTab",
    "scripting",
    "identity"
  ],
  "oauth2": {
    "client_id": "407769393248-p1s800ebfm26qdvre4hvvqgqceo46bgj.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "quick-save": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Quick-save current tab to LumeBoard"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' https://*.unsplash.com https://www.google.com https://*.gstatic.com https://*.pinimg.com https://icons.duckduckgo.com https://s2.googleusercontent.com data: blob:"
  },
  "action": {
    "default_title": "LumeBoard"
  }
}